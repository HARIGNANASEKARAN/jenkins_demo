pipeline {
    agent none 
    
    stages {
        stage('Build') {
            agent {
                label 'Node1' // Specify a specific agent label for this stage
            }
            steps {
                sh 'docker build -t myapp .'
            }
        }
        stage('Test') {
            agent {
                label 'Node2' // Specify the same agent label for consistency
            }
            steps {
                sh 'docker run myapp test'
            }
        }
        stage('Deploy') {
            agent {
                label 'Master_Jenkins' // Specify the same agent label for consistency
            }
            steps {
                sh 'docker push myapp:latest'
            }
        }
    }
}