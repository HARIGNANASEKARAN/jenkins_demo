pipeline {
    agent none 
    
    stages {
        stage('Build') {
            agent {
                label 'Node1' // Specify a specific agent label for this stage
            }
            steps {
                sh '''
                echo 'docker build -t myapp 3.' 
                '''
            }
        }
        stage('Test') {
            agent {
                label 'Node2' // Specify the same agent label for consistency
            }
            steps {
                sh '''
                echo 'docker run myapp test 3'
                '''
            }
        }
        stage('Deploy') {
            agent {
                label 'Master_Jenkins' // Specify the same agent label for consistency
            }
            steps {
                sh '''
                echo 'docker push myapp:latest 3'
                '''
            }
        }
    }
}